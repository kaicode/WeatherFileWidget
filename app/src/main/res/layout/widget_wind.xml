<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="#101223">

    <ImageView
        android:id="@+id/image_direction"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_alignParentStart="true"
        android:contentDescription="Wind direction dial"
        android:src="@drawable/ic_placeholder" />

    <ImageView
        android:id="@+id/image_speed"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_toRightOf="@id/image_direction"
        android:layout_marginStart="12dp"
        android:contentDescription="Wind speed dial"
        android:src="@drawable/ic_placeholder" />

    <TextView
        android:id="@+id/text_speed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/image_speed"
        android:layout_alignStart="@id/image_speed"
        android:text="0.0 m/s"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/text_direction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/image_direction"
        android:layout_alignStart="@id/image_direction"
        android:text="0°"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/text_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:text="--:--"
        android:textColor="#88FFFFFF"
        android:textSize="12sp" />

</RelativeLayout>

